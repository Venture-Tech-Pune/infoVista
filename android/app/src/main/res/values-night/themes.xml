<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.InfoVista" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Control colors -->
        <item name="colorControlNormal">@color/accent</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlHighlight">@color/accent</item>

        <!-- Dialog themes -->
        <item name="android:datePickerDialogTheme">@style/Theme.InfoVista.Dialog</item>
        <item name="android:timePickerDialogTheme">@style/Theme.InfoVista.Dialog</item>

        <!-- Material component styles -->
        <item name="textInputStyle">@style/Widget.InfoVista.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.InfoVista.Button</item>
    </style>

    <!-- Custom Outlined Button style -->
    <style name="Widget.InfoVista.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/accent</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Custom Dialog theme to ensure button visibility -->
    <style name="Theme.InfoVista.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorHighlight">@color/accent</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.InfoVista.Button.Text</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.InfoVista.Button.Text</item>
    </style>

    <style name="Widget.InfoVista.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
    </style>
</resources>