<resources>
    <!-- Base application theme -->
    <style name="Theme.InfoVista" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        
        <!-- Material component styles -->
        <item name="textInputStyle">@style/Widget.InfoVista.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.InfoVista.Button</item>
    </style>
    
    <!-- Custom TextInputLayout style -->
    <style name="Widget.InfoVista.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="editTextColor">@color/text_primary</item>
    </style>
    
    <!-- Custom Button style -->
    <style name="Widget.InfoVista.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_light</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Splash screen theme -->
    <style name="Theme.InfoVista.Splash" parent="Theme.InfoVista">
        <item name="android:windowBackground">@drawable/bg_starry</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>